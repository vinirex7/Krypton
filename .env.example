# .env.example — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves reais:
#   cp .env.example .env
#
# ⚠️  NUNCA commitar o arquivo .env real no repositório.
#     Ele já está no .gitignore — mas confirme antes do primeiro push.

BINANCE_API_KEY=sua_chave_api_aqui
BINANCE_API_SECRET=seu_secret_aqui

# Permissões necessárias na API Binance:
#   ✅ Enable Reading
#   ✅ Enable Spot & Margin Trading
#   ❌ NUNCA habilitar Enable Withdrawals
#   ❌ NUNCA habilitar Enable Futures
#
# Segurança adicional:
#   - Restringir a API ao IP fixo do seu VPS
#   - Ativar 2FA na conta Binance (Google Authenticator ou hardware key)
